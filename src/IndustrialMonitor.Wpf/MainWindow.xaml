<Window
    x:Class="IndustrialMonitor.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i18n="clr-namespace:IndustrialMonitor.Wpf.Markup"
    Title="{i18n:Tr App.Title}"
    Width="1100"
    Height="720"
    MinWidth="800"
    MinHeight="500"
    Background="{DynamicResource AppBackgroundBrush}"
    WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="24,16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextBrush}"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{i18n:Tr App.Title}" />

                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        x:Name="LanguageToggleButton"
                        MinWidth="92"
                        Margin="0,0,10,0"
                        Click="LanguageToggleButton_Click"
                        Content="{i18n:Tr Language.Toggle}"
                        Style="{StaticResource ButtonSecondary}" />

                    <Button
                        x:Name="ThemeToggleButton"
                        Width="34"
                        Height="34"
                        Click="ThemeToggleButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Content="T"
                        Cursor="Hand"
                        Foreground="{DynamicResource TextBrush}"
                        ToolTip="{i18n:Tr Theme.Toggle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            x:Name="RootContainer"
            Grid.Row="1"
            Background="{DynamicResource AppBackgroundBrush}" />
    </Grid>
</Window>
