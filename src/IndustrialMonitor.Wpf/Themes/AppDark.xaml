<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorPrimary">#60A5FA</Color>
    <Color x:Key="ColorPrimaryHover">#3B82F6</Color>
    <Color x:Key="ColorPrimaryPressed">#2563EB</Color>
    <Color x:Key="ColorText">#E5E7EB</Color>
    <Color x:Key="ColorTextMuted">#9CA3AF</Color>
    <Color x:Key="ColorBorder">#374151</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#111827" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1F2937" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#273244" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource ColorPrimaryPressed}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ColorText}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource ColorBorder}" />

    <SolidColorBrush x:Key="ButtonDisabledForegroundBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="ButtonDisabledBackgroundBrush" Color="#1F2937" />
    <SolidColorBrush x:Key="ButtonDisabledBorderBrush" Color="#374151" />
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#273244" />
    <SolidColorBrush x:Key="ButtonSecondaryPressedBrush" Color="#334155" />
    <SolidColorBrush x:Key="ButtonSecondaryHoverBorderBrush" Color="#64748B" />
    <SolidColorBrush x:Key="ButtonSecondaryPressedBorderBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="DangerForegroundBrush" Color="#FCA5A5" />
    <SolidColorBrush x:Key="DangerBorderBrush" Color="#7F1D1D" />
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="#3F1F25" />

    <SolidColorBrush x:Key="GridAlternateRowBrush" Color="#182231" />
    <SolidColorBrush x:Key="GridLineBrush" Color="#2F3A4B" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#273244" />
    <SolidColorBrush x:Key="GridHeaderBorderBrush" Color="#374151" />
    <SolidColorBrush x:Key="GridSelectedBrush" Color="#1E3A5F" />
    <SolidColorBrush x:Key="GridRowHoverBrush" Color="#24344A" />

    <SolidColorBrush x:Key="DividerBrush" Color="#374151" />
    <SolidColorBrush x:Key="StatusEnabledBackgroundBrush" Color="#123524" />
    <SolidColorBrush x:Key="StatusDisabledBackgroundBrush" Color="#3F1F25" />
    <SolidColorBrush x:Key="StatusEnabledForegroundBrush" Color="#86EFAC" />
    <SolidColorBrush x:Key="StatusDisabledForegroundBrush" Color="#FCA5A5" />
</ResourceDictionary>
