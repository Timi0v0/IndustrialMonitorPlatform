<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorPrimary">#2563EB</Color>
    <Color x:Key="ColorPrimaryHover">#1D4ED8</Color>
    <Color x:Key="ColorPrimaryPressed">#1E40AF</Color>
    <Color x:Key="ColorText">#111827</Color>
    <Color x:Key="ColorTextMuted">#6B7280</Color>
    <Color x:Key="ColorBorder">#D8DEE8</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F6FA" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource ColorPrimaryPressed}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ColorText}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource ColorBorder}" />

    <SolidColorBrush x:Key="ButtonDisabledForegroundBrush" Color="#9CA3AF" />
    <SolidColorBrush x:Key="ButtonDisabledBackgroundBrush" Color="#E5E7EB" />
    <SolidColorBrush x:Key="ButtonDisabledBorderBrush" Color="#D1D5DB" />
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#F9FAFB" />
    <SolidColorBrush x:Key="ButtonSecondaryPressedBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="ButtonSecondaryHoverBorderBrush" Color="#9CA3AF" />
    <SolidColorBrush x:Key="ButtonSecondaryPressedBorderBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="DangerForegroundBrush" Color="#B91C1C" />
    <SolidColorBrush x:Key="DangerBorderBrush" Color="#FECACA" />
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="#FFF7F7" />

    <SolidColorBrush x:Key="GridAlternateRowBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="GridLineBrush" Color="#EEF2F7" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="GridHeaderBorderBrush" Color="#E5EAF2" />
    <SolidColorBrush x:Key="GridSelectedBrush" Color="#DBEAFE" />
    <SolidColorBrush x:Key="GridRowHoverBrush" Color="#EFF6FF" />

    <SolidColorBrush x:Key="DividerBrush" Color="#E5EAF2" />
    <SolidColorBrush x:Key="StatusEnabledBackgroundBrush" Color="#DCFCE7" />
    <SolidColorBrush x:Key="StatusDisabledBackgroundBrush" Color="#FEE2E2" />
    <SolidColorBrush x:Key="StatusEnabledForegroundBrush" Color="#166534" />
    <SolidColorBrush x:Key="StatusDisabledForegroundBrush" Color="#991B1B" />
</ResourceDictionary>
