<UserControl
    x:Class="IndustrialMonitor.Wpf.Views.DeviceEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i18n="clr-namespace:IndustrialMonitor.Wpf.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:IndustrialMonitor.Wpf.ViewModels"
    Width="560"
    d:DataContext="{d:DesignInstance vm:DeviceEditViewModel}"
    mc:Ignorable="d">
    <Border Padding="22" Background="{DynamicResource SurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock
                    FontSize="20"
                    Style="{StaticResource PageTitleText}"
                    Text="{i18n:Tr Device.EditTitle}" />
                <TextBlock Style="{StaticResource PageSubtitleText}" Text="{i18n:Tr Device.EditSubtitle}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextMutedBrush}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="{i18n:Tr Device.BasicInfo}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FormLabelText}" Text="{i18n:Tr Device.Code}" />
                            <hc:TextBox
                                MaxLength="50"
                                hc:InfoElement.Placeholder="{i18n:Tr Device.CodePlaceholder}"
                                Text="{Binding DeviceCode}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FormLabelText}" Text="{i18n:Tr Device.Name}" />
                            <hc:TextBox
                                MaxLength="100"
                                hc:InfoElement.Placeholder="{i18n:Tr Device.NamePlaceholder}"
                                Text="{Binding DeviceName}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FormLabelText}" Text="{i18n:Tr Device.Type}" />
                            <hc:TextBox
                                hc:InfoElement.Placeholder="{i18n:Tr Device.TypePlaceholder}"
                                Text="{Binding DeviceType}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FormLabelText}" Text="{i18n:Tr Device.Protocol}" />
                            <hc:ComboBox Text="{Binding ProtocolType}">
                                <ComboBoxItem Content="TCP" IsSelected="True" />
                                <ComboBoxItem Content="Modbus" />
                                <ComboBoxItem Content="MQTT" />
                            </hc:ComboBox>
                        </StackPanel>
                    </Grid>

                    <Border
                        Height="1"
                        Margin="0,20,0,16"
                        Background="{DynamicResource DividerBrush}" />

                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextMutedBrush}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="{i18n:Tr Device.Communication}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FormLabelText}" Text="{i18n:Tr Device.IpAddress}" />
                            <hc:TextBox
                                hc:InfoElement.Placeholder="192.168.1.100"
                                Text="{Binding IpAddress}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FormLabelText}" Text="{i18n:Tr Device.PortLabel}" />
                            <hc:NumericUpDown
                                Increment="1"
                                Maximum="65535"
                                Minimum="1"
                                Value="{Binding Port}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FormLabelText}" Text="{i18n:Tr Device.IntervalLabel}" />
                            <hc:NumericUpDown
                                Increment="1000"
                                Maximum="60000"
                                Minimum="1000"
                                Value="{Binding CollectInterval}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                            <CheckBox
                                Margin="0,0,0,8"
                                Content="{i18n:Tr Device.EnableDevice}"
                                IsChecked="{Binding IsEnabled}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Style="{StaticResource FormLabelText}" Text="{i18n:Tr Device.Remark}" />
                        <hc:TextBox
                            Height="76"
                            AcceptsReturn="True"
                            MaxLength="500"
                            hc:InfoElement.Placeholder="{i18n:Tr Device.RemarkPlaceholder}"
                            Text="{Binding Remark}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="1"
                    Width="112"
                    Command="{Binding SaveCommand}"
                    Content="{i18n:Tr Common.Save}"
                    Style="{StaticResource ButtonPrimary}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
