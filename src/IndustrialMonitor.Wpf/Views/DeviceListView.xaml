<UserControl
    x:Class="IndustrialMonitor.Wpf.Views.DeviceListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i18n="clr-namespace:IndustrialMonitor.Wpf.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:IndustrialMonitor.Wpf.ViewModels"
    d:DataContext="{d:DesignInstance vm:DeviceListViewModel}"
    mc:Ignorable="d">
    <Grid Margin="24" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource PageTitleText}" Text="{i18n:Tr Device.Title}" />
                <TextBlock Style="{StaticResource PageSubtitleText}" Text="{i18n:Tr Device.Subtitle}" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding RefreshCommand}"
                    Content="{i18n:Tr Common.Refresh}"
                    Style="{StaticResource ButtonSecondary}" />
                <Button
                    Command="{Binding AddDeviceCommand}"
                    Content="{i18n:Tr Device.Add}"
                    Style="{StaticResource ButtonPrimary}" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Margin="0,0,0,12"
            Padding="14"
            Style="{StaticResource SurfaceCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <hc:SearchBar
                    Grid.Column="0"
                    Width="360"
                    HorizontalAlignment="Left"
                    hc:InfoElement.Placeholder="{i18n:Tr Device.SearchPlaceholder}"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextMutedBrush}"
                    Text="{i18n:TrFormat Device.CurrentTotal, Value={Binding TotalCount}}" />
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Padding="0"
            Style="{StaticResource SurfaceCard}">
            <DataGrid
                AutoGenerateColumns="False"
                FontSize="13"
                IsReadOnly="True"
                ItemsSource="{Binding Devices}"
                SelectedItem="{Binding SelectedDevice}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding DeviceCode}"
                        Header="{i18n:Tr Device.Code}" />
                    <DataGridTextColumn
                        Width="1.4*"
                        Binding="{Binding DeviceName}"
                        Header="{i18n:Tr Device.Name}" />
                    <DataGridTextColumn
                        Width="1.1*"
                        Binding="{Binding DeviceType}"
                        Header="{i18n:Tr Device.Type}" />
                    <DataGridTextColumn
                        Width="90"
                        Binding="{Binding ProtocolType}"
                        Header="{i18n:Tr Device.Protocol}" />
                    <DataGridTextColumn
                        Width="140"
                        Binding="{Binding IpAddress}"
                        Header="{i18n:Tr Device.IpAddress}" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding Port}"
                        Header="{i18n:Tr Device.Port}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding CollectInterval}"
                        Header="{i18n:Tr Device.CollectInterval}" />
                    <DataGridTemplateColumn Width="90" Header="{i18n:Tr Device.Status}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="9,3"
                                    HorizontalAlignment="Left"
                                    CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource StatusEnabledBackgroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Background" Value="{DynamicResource StatusDisabledBackgroundBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource StatusEnabledForegroundBrush}"
                                            Text="{i18n:Tr Device.Enabled}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource StatusDisabledForegroundBrush}"
                                            Text="{i18n:Tr Device.Disabled}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="150" Header="{i18n:Tr Device.Operation}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Margin="0,0,6,0"
                                        Command="{Binding DataContext.EditDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="{i18n:Tr Common.Edit}"
                                        Style="{StaticResource ButtonSmallSecondary}" />
                                    <Button
                                        Command="{Binding DataContext.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="{i18n:Tr Common.Delete}"
                                        Style="{StaticResource ButtonDangerSmall}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource TextMutedBrush}"
                Text="{i18n:TrFormat Device.TotalRecords, Value={Binding TotalCount}}" />
            <Grid
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                <TextBlock
                    Foreground="{DynamicResource TextMutedBrush}"
                    Text="{i18n:Tr Device.DataReady}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock
                    Foreground="{DynamicResource TextMutedBrush}"
                    Text="{i18n:Tr Device.Loading}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
