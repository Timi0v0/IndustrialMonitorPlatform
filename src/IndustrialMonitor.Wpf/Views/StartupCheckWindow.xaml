<Window
    x:Class="IndustrialMonitor.Wpf.Views.StartupCheckWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:startupChecks="clr-namespace:IndustrialMonitor.Wpf.StartupChecks"
    Title="启动环境检查"
    Width="760"
    Height="520"
    MinWidth="640"
    MinHeight="420"
    Background="{DynamicResource AppBackgroundBrush}"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock
                Foreground="{DynamicResource TextBrush}"
                FontSize="24"
                FontWeight="SemiBold"
                Text="{Binding Title}" />
            <TextBlock
                Margin="0,8,0,0"
                Foreground="{DynamicResource TextMutedBrush}"
                FontSize="13"
                Text="{Binding Description}"
                TextWrapping="Wrap" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="0"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8">
            <ListView
                BorderThickness="0"
                ItemsSource="{Binding Results}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type startupChecks:StartupCheckResult}">
                        <Grid Margin="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="70"
                                Height="26"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="{Binding Severity, Converter={StaticResource StartupSeverityBackgroundConverter}}"
                                CornerRadius="4">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="{Binding Severity, Converter={StaticResource StartupSeverityTextConverter}}" />
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    Foreground="{DynamicResource TextBrush}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Title}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Text="{Binding Message}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Text="{Binding Remedy}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <StackPanel
            Grid.Row="2"
            Margin="0,18,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                MinWidth="110"
                Margin="0,0,10,0"
                Click="CopyButton_Click"
                Content="复制诊断信息"
                Style="{StaticResource ButtonSecondary}" />
            <Button
                MinWidth="88"
                Margin="0,0,10,0"
                Click="RetryButton_Click"
                Content="重试"
                Style="{StaticResource ButtonSecondary}" />
            <Button
                MinWidth="110"
                Margin="0,0,10,0"
                Click="ContinueButton_Click"
                Content="继续进入系统"
                IsEnabled="{Binding AllowContinue}"
                Style="{StaticResource ButtonPrimary}" />
            <Button
                MinWidth="88"
                Click="ExitButton_Click"
                Content="退出"
                Style="{StaticResource ButtonSecondary}" />
        </StackPanel>
    </Grid>
</Window>
